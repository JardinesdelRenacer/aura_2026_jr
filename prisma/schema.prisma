// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

// Roles
enum Role {
  MASTER
  ADMIN
}

// Estados
enum EstadoSede {
  ACTIVA
  INACTIVA
}

enum EstadoPantalla {
  OFFLINE
  ONLINE
  MANTENIMIENTO
  ERROR
}

// Usuarios
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String

  nombres       String?
  apellidos     String?
  cedula        String?
  telefono      String?
  departamento  String?
  ciudad        String?
  estado        String?  @default("ACTIVO")

  lastSeen      DateTime?

  role          Role     @default(ADMIN)
  sede          Sede?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Sede {
  id      		      String                  @id @default(cuid())

  departamento  	  String
  ciudad        	  String
  nombre        	  String  		    
  estado            EstadoSede               @default(INACTIVA)

  numeroSalas       Int                      @default(1)
  salaVip           Boolean                  @default(false)
  
  adminId 		      String?                  @unique
  admin   		      User?                    @relation(fields: [adminId], references: [id])

  obituarios      	Obituario[]
  media           	Media[]
  configuracion   	ConfiguracionPantalla?

  presentaciones    Presentacion[] 

  lastSeen          DateTime?     

  pantallas         PantallaCliente[]
  codigos           CodigoRegistro[]

  createdAt 		    DateTime                  @default(now())
  updatedAt 		    DateTime                  @updatedAt
}

model Obituario {
  id          String    @id @default(cuid())

  sedeId      String
  sede        Sede      @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  sala        String

  name        String
  surname     String

  dob         String?
  dod         String?

  timeStart   String?
  timeEnd     String?

  cemetery    String?
  endTime     String?
  endDate     String?

  // --- NUEVOS CAMPOS DE EUCARISTÍA ---
  massTime       String?  // Hora de la misa
  massChurch     String?  // Nombre del lugar
  massChurchType String?  @default("Parroquia") // Tipo: Parroquia, Capilla, etc.
  massAddress    String?  // Dirección del lugar

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([sedeId, sala])
}

model ConfiguracionPantalla {
  id                  String    @id @default(cuid())

  sedeId              String    @unique
  sede                Sede      @relation(fields: [sedeId], references: [id])

  autoPlay            Boolean   @default(true)
  seconds             Int       @default(10)

  transitionEffect    String    @default("fade")

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Media {
  id        String    @id @default(cuid())

  sedeId    String
  sede      Sede      @relation(fields: [sedeId], references: [id])

  url       String

  fileName  String

  type      String

  orden     Int

  room      String?

  createdAt DateTime  @default(now())
}

model Presentacion {
  id                  String              @id @default(cuid())
  nombre              String

  projectionMode      String              @default("classic")
  selectedImage       Int                 @default(0)

  roomsToShow         Json?
  obituaries          Json?

  sedeId              String
  sede                Sede                @relation(fields: [sedeId], references: [id])

  pantallas           PantallaCliente[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}


model PantallaCliente {
  id                  String         @id @default(cuid())

  nombre              String

  token               String          @unique @default(uuid())

  online              Boolean         @default(false)

  estado              EstadoPantalla  @default(OFFLINE)

  reiniciar           Boolean         @default(false)

  lastSeen            DateTime?

  sedeId              String          
  sede                Sede            @relation(fields: [sedeId], references: [id])

  presentacionId      String?
  presentacion        Presentacion?   @relation(fields: [presentacionId], references: [id])

  screenWidth         Int?
  screenHeight        Int?

  viewportWidth       Int?
  viewportHeight      Int?

  ip                  String?
  userAgent           String?
  language            String?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([sedeId])
  @@index([estado])
  @@index([online])
  
}

model CodigoRegistro{
  id              String            @id @default(cuid())

  codigo          String            @unique

  pantallaNombre  String?

  sedeId          String
  sede            Sede              @relation(fields: [sedeId], references:[id])

  usado           Boolean           @default(false)

  expiresAt       DateTime

  utilizadoAt     DateTime?

  createdAt       DateTime          @default(now())
}
