generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // Puede ser "MASTER" o "ADMIN"
  sede      Sede?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sede {
  id          String   @id @default(cuid())
  nombre      String
  estado      String   @default("Inactiva")
  adminId     String   @unique
  admin       User     @relation(fields: [adminId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}